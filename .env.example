# 1) Copy this file to `.env` in the repo root (Vite reads it; restart `pnpm dev` after edits).
# 2) Copy `backend/.env.example` to `backend/.env` and add API keys for live AI (see README).

VITE_DATA_SOURCE=indexeddb
VITE_DEBUG=true
# Parent summary generator: set true to call the backend (uses tokens); false = local mock.
VITE_USE_LLM=false

# Use the FastAPI backend (same origin as below) when you want API-backed data + AI.
# VITE_DATA_SOURCE=api
VITE_API_BASE_URL=http://localhost:8787
